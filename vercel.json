{
  "services": {
    "frontend": {
      "root": "frontend/",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend/",
      "entrypoint": "src/server.ts",
      "framework": "express",
      "buildCommand": "npm run build"
    }
  },
  "rewrites": [
    {
      "source": "/api/backend",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/api/backend/:path*",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "frontend"
      }
    }
  ]
}
